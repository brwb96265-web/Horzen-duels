local function CreateBtn(name, callback)
    local b = Instance.new("TextButton", SideButtons)
    b.Text = name
    b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.GothamBold
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)
    local act = false
    b.MouseButton1Click:Connect(function()
        act = not act
        b.BackgroundColor3 = act and Color3.fromRGB(200, 0, 50) or Color3.fromRGB(30, 30, 30)
        callback(act)
    end)
end

CreateBtn("Auto L", function(v) _G.AutoSteal = v _G.Mode = "Left" end)
CreateBtn("Auto R", function(v) _G.AutoSteal = v _G.Mode = "Right" end)

-- [ CORE ENGINE ]

local function CheckProximity()
    local targetFound = false
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            local part = v.Parent:IsA("BasePart") and v.Parent or v.Parent.Parent
            if part and part:IsA("BasePart") then
                local dist = (Player.Character.HumanoidRootPart.Position - part.Position).Magnitude
                if dist <= _G.GrabRange then
                    DistVal.Text = tostring(math.floor(dist))
                    targetFound = true
                    break
                end
            end
        end
    end
    ReadyBar.Visible = targetFound
end

RunService.RenderStepped:Connect(function()
    CheckProximity()
end)

task.spawn(function()
    while task.wait(0.01) do
        if _G.AutoSteal then
            pcall(function()
                local char = Player.Character
                local root = char.HumanoidRootPart
                local isCarrying = char:FindFirstChild("Brainrot") or char:FindFirstChildOfClass("Tool")
                
                if not isCarrying then
                    root.CFrame = (_G.Mode == "Left") and CFrame.new(Pos.LeftEnemy) or CFrame.new(Pos.RightEnemy)
                    for _, v in pairs(workspace:GetDescendants()) do
                        if v:IsA("ProximityPrompt") then
                            v.HoldDuration = 0
                            fireproximityprompt(v)
                        end
                    end
                else
                    root.CFrame = (_G.Mode == "Left") and CFrame.new(Pos.LeftHome) or CFrame.new(Pos.RightHome)
                end
            end)
        end
    end
end)

-- [ ANTI-RAGDOLL HANDLER ]
RunService.Stepped:Connect(function()
    if _G.AntiRagdoll and Player.Character and Player.Character:FindFirstChild("Humanoid") then
        local hum = Player.Character.Humanoid
        if hum:GetState() == Enum.HumanoidStateType.Ragdoll or hum:GetState() == Enum.HumanoidStateType.FallingDown then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end
end)
